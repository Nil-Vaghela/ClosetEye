{
  "expo": {
    "name": "ClosetEye",
    "slug": "closeteye",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.closeteye.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ClosetEye needs camera access to photograph your clothing items."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.closeteye.app",
      "permissions": [
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker"
    ]
  }
}
