GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple Sign In
APPLE_BUNDLE_ID=com.closeteye.app

OPENAI_API_KEY=sk-...
REMOVEBG_API_KEY=...
DEBUG=true
